{
  "id": null,
  "title": "Enterprise App Dashboard",
  "tags": ["enterprise", "mern"],
  "timezone": "browser",
  "schemaVersion": 36,
  "refresh": "10s",
  "panels": [
    {
      "id": 1,
      "title": "CPU Usage",
      "type": "stat",
      "targets": [
        {
          "expr": "rate(container_cpu_usage_seconds_total{namespace=\"enterprise-app-prod\"}[5m])",
          "legendFormat": "{{ pod }}"
        }
      ],
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 0}
    },
    {
      "id": 2,
      "title": "Memory Usage",
      "type": "stat",
      "targets": [
        {
          "expr": "container_memory_usage_bytes{namespace=\"enterprise-app-prod\"}",
          "legendFormat": "{{ pod }}"
        }
      ],
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 0}
    },
    {
      "id": 3,
      "title": "Pod Count",
      "type": "stat",
      "targets": [
        {
          "expr": "count(kube_pod_status_phase{namespace=\"enterprise-app-prod\", phase=\"Running\"})",
          "legendFormat": "Running Pods"
        }
      ],
      "gridPos": {"h": 8, "w": 24, "x": 0, "y": 8}
    }
  ]
}